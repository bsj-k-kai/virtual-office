# サーバー
PORT=3001
NODE_ENV=production

# Google OAuth（必須）— https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=985297110533-kcolou61ta9at2rugr9jpa8j4mhnalfq.apps.googleusercontent.com
# クライアントビルド時にも同じ値を設定
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# セッション署名（本番ではランダムな長い文字列に変更）
JWT_SECRET=change-me-in-production

# 許可するメールドメイン
ALLOWED_EMAIL_DOMAIN=bravesoft.co.jp

# 本番ではデモボット無効（開発時のみ true 推奨）
ENABLE_DEMO_BOTS=false

# フロントを別ドメインで配信する場合（カンマ区切り）
# ALLOWED_ORIGINS=https://office.example.com

# クライアントビルド時（通常は未設定で同一オリジン）
# VITE_SERVER_URL=https://office.example.com

# WebRTC が繋がらない場合の TURN（Metered / Twilio 等）
# VITE_TURN_URL=turn:global.relay.metered.ca:80
# VITE_TURN_USERNAME=...
# VITE_TURN_CREDENTIAL=...
